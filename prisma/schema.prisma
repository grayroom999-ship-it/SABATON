generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccessoryType {
  horn
  socks
  laces
  cleaner
}

enum ShoeCategoryName {
  casual
  formal
  boots
  all
}

model Product {
  id               String    @id @default(cuid())
  name             String
  description      String?
  price            Float
  imageUrl         String?
  hoverImageUrl    String?
  category         String?             // "shoe" or "accessory"
  gender           String
  material         String?
  accessoryType    AccessoryType?
  crossSellScore   Int                @default(0)
  searchText       String?
  embedding        Unsupported("vector")?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  variants         Variant[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  fitsCategories   AccessoryShoeCategory[]
  shoeCategories   ShoeCategoryOnProduct[]
  // Analytics relations
  productViews     ProductView[]
  addToCartEvents  AddToCartEvent[]
  dailyStats       DailyProductStats[]
  // purchaseEvents removed – we can get product purchases via OrderItem
  @@index([category])
  @@index([gender])
}

model Variant {
  id         String      @id @default(cuid())
  sku        String      @unique
  size       Int
  color      String?
  price      Float?
  stock      Int         @default(0)
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]
  // Analytics relation
  addToCartEvents AddToCartEvent[]
}

// ─── User Profile ──────────────────────────────────────────
model UserProfile {
  id              Int      @id @default(autoincrement())
  phone           String   @unique
  name            String
  email           String?
  address         String
  city            String?   // e.g., Buea, Limbe
  preferredSize   Int?      // for future recommendations
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  sessions        Session[]
  // Analytics relations
  productViews    ProductView[]
  searchQueries   SearchQuery[]
  addToCartEvents AddToCartEvent[]
  purchaseEvents  PurchaseEvent[]
}

// ─── Session ──────────────────────────────────────────────
model Session {
  id              Int       @id @default(autoincrement())
  sessionId       String    @unique
  userProfileId   Int?      // optional until phone is provided
  userProfile     UserProfile? @relation(fields: [userProfileId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Order ─────────────────────────────────────────────────
model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  userProfileId    Int?
  userProfile      UserProfile? @relation(fields: [userProfileId], references: [id])
  cartId           String
  cart             Cart        @relation("CartOrders", fields: [cartId], references: [id])
  customerName     String
  customerPhone    String
  deliveryAddress  String
  totalAmount      Int          // or Float if you need decimals
  paymentStatus    String      @default("pending")
  orderStatus      String      @default("confirmed")
  trackingNumber   String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  items            OrderItem[]
  notifications    VendorNotification[]
  // Analytics relation
  purchaseEvents   PurchaseEvent[]
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float
  productId  String
  orderId    String
  variantId  String?
  product    Product  @relation(fields: [productId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
  variant    Variant? @relation(fields: [variantId], references: [id])
  @@unique([orderId, productId, variantId])
}

model CartItem {
  id         String   @id @default(cuid())
  quantity   Int      @default(1)
  productName String?
  price      Float
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  variantId  String?
  variant    Variant? @relation(fields: [variantId], references: [id])
  @@unique([cartId, productId, variantId])
}

model Cart {
  id        String    @id @default(cuid())
  orders    Order[]   @relation("CartOrders")   // ← explicit opposite side
  sessionId String    @unique
  userId    String?
  items     CartItem[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Analytics relation
  addToCartEvents AddToCartEvent[]
}

model ShoeCategory {
  id          String   @id @default(cuid())
  name        ShoeCategoryName @unique
  accessories AccessoryShoeCategory[]
  products    ShoeCategoryOnProduct[]
}

model AccessoryShoeCategory {
  id             String       @id @default(cuid())
  accessoryId    String
  shoeCategoryId String
  accessory      Product      @relation(fields: [accessoryId], references: [id], onDelete: Cascade)
  shoeCategory   ShoeCategory @relation(fields: [shoeCategoryId], references: [id], onDelete: Cascade)
  @@unique([accessoryId, shoeCategoryId])
}

model ShoeCategoryOnProduct {
  id             String       @id @default(cuid())
  productId      String
  shoeCategoryId String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  shoeCategory   ShoeCategory @relation(fields: [shoeCategoryId], references: [id], onDelete: Cascade)
  @@unique([productId, shoeCategoryId])
}

// ─── Vendor Notification ──────────────────────────────────
model VendorNotification {
  id          Int       @id @default(autoincrement())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])
  message     String
  isRead      Boolean   @default(false)
  sentAt      DateTime  @default(now())
}

// ═══════════════════════════════════════════════════════════
//  NEW: Customer Behavior Analytics Models (add‑only)
// ═══════════════════════════════════════════════════════════

model ProductView {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sessionId     String   // references a session identifier
  userProfileId Int?     // optional if user is authenticated
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id])
  viewedAt      DateTime @default(now())
  referrer      String?
  userAgent     String?
  ipAddress     String?
}

model SearchQuery {
  id            String   @id @default(cuid())
  query         String
  sessionId     String
  userProfileId Int?
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id])
  resultCount   Int?
  createdAt     DateTime @default(now())
}

model AddToCartEvent {
  id            String   @id @default(cuid())
  sessionId     String
  userProfileId Int?
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  variantId     String?
  variant       Variant? @relation(fields: [variantId], references: [id])
  quantity      Int
  cartId        String
  cart          Cart     @relation(fields: [cartId], references: [id])
  createdAt     DateTime @default(now())
}

model PurchaseEvent {
  id            String   @id @default(cuid())
  sessionId     String
  userProfileId Int?
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id])
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  totalAmount   Float
  createdAt     DateTime @default(now())
}

model DailyProductStats {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  views         Int      @default(0)
  addToCarts    Int      @default(0)
  purchases     Int      @default(0)
  revenue       Float    @default(0)
  @@unique([productId, date])
}