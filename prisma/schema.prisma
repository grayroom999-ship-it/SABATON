generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccessoryType {
  horn
  socks
  laces
  cleaner
}

enum ShoeCategoryName {
  casual
  formal
  boots
  all
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  hoverImageUrl  String?          // ✅ already present
  category    String?             // "shoe" or "accessory"
  gender      String              // ✅ stays as String (no enum)
  material    String?
  accessoryType   AccessoryType?
  crossSellScore  Int            @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  variants    Variant[]
  orderItems  OrderItem[]
  cartItems   CartItem[]

  fitsCategories AccessoryShoeCategory[]
  shoeCategories ShoeCategoryOnProduct[]

  @@index([category])
  @@index([gender])
}

model Variant {
  id        String   @id @default(cuid())
  sku       String   @unique
  size      Int
  color     String?
  price     Float?
  stock     Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]
}

model Order {
  id         String      @id @default(cuid())
  customerId String?
  total      Float
  status     String      @default("pending")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float
  productId  String
  orderId    String
  variantId  String?
  product    Product  @relation(fields: [productId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
  variant    Variant? @relation(fields: [variantId], references: [id])

  @@unique([orderId, productId, variantId])
}

model CartItem {
  id         String   @id @default(cuid())
  quantity   Int      @default(1)
  productName String?
  price      Float
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  variantId  String?
  variant    Variant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
}

model Cart {
  id        String   @id @default(cuid())
  sessionId String   @unique
  userId    String?
  items     CartItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShoeCategory {
  id          String   @id @default(cuid())
  name        ShoeCategoryName @unique
  accessories AccessoryShoeCategory[]
  products    ShoeCategoryOnProduct[]
}

model AccessoryShoeCategory {
  id             String       @id @default(cuid())
  accessoryId    String
  shoeCategoryId String
  accessory      Product      @relation(fields: [accessoryId], references: [id], onDelete: Cascade)
  shoeCategory   ShoeCategory @relation(fields: [shoeCategoryId], references: [id], onDelete: Cascade)

  @@unique([accessoryId, shoeCategoryId])
}

model ShoeCategoryOnProduct {
  id             String       @id @default(cuid())
  productId      String
  shoeCategoryId String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  shoeCategory   ShoeCategory @relation(fields: [shoeCategoryId], references: [id], onDelete: Cascade)

  @@unique([productId, shoeCategoryId])
}